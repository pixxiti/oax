{
  "name": "@pixxiti/oax-hooks",
  "version": "1.0.1",
  "description": "React Query v5 hooks for oax API clients",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node ../../scripts/fix-esm-imports.mjs dist",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react-query",
    "hooks",
    "openapi",
    "zod",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@pixxiti/oax-core": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0"
  }
}
